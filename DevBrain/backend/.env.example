# Postgres connection string.
# Free option: create a project at https://supabase.com, then use its
# "Connection string" (Session pooler) from Project Settings > Database.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Any long random string, used to sign JWTs.
JWT_SECRET=change-this-to-a-long-random-string

# Free tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
